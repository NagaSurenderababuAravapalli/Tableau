              <flipboard active-id='2' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='AI Jobs by Industry,   Ind Experience level &amp; Salary distribution by Industry. Retail  Industry generates higher number AI jobs 1063 whereas  Education industry is the lowest one 956 jobs. ' captured-sheet='Dashboard 1_Naga' id='1'>
                    <capturedDeltas>
                      <worksheet name='AI Jobs by Industry_Naga'>
                        <filter class='categorical' column='[federated.1ke8xct1tih9vt1228a1515qct8i].[Action (Experience Level)]'>
                          <groupfilter function='level-members' level='[experience_level]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                      <worksheet name='Salary Distribution by Industry_Naga'>
                        <filter class='categorical' column='[federated.1ke8xct1tih9vt1228a1515qct8i].[Action (Experience Level)]'>
                          <groupfilter function='level-members' level='[experience_level]' user:ui-enumeration='all' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Some countries China, Denmark, Germany, Japan &amp; United Kingdom are posting more AI Jobs due to its high central datacenters. So It is better to expand other countries as well across all the industries. All the industries having small, medium and large size so it is recommended to expose &amp; develop the industries so that respective company size also grown together.' captured-sheet='Dashboard 2_Naga' id='2' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
